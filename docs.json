{
  "$schema": "https://mintlify.com/docs.json",
  "name": "svelte5-router",
  "theme": "luma",
  "colors": {
    "primary": "#07baf0",
    "light": "#5fc9de"
  },
  "favicon": "https://media.brand.dev/eaaf8ca6-e1ac-48d9-89de-67a817a3128f.jpg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/jpcutshall/svelte5-router"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/jpcutshall/svelte5-router"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/basic-routing",
              "guides/dynamic-routes",
              "guides/nested-routers",
              "guides/lazy-loading",
              "guides/ssr",
              "guides/view-transitions"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Components",
            "pages": [
              "api/router",
              "api/route",
              "api/link"
            ]
          },
          {
            "group": "Functions & Actions",
            "pages": [
              "api/navigate",
              "api/listen",
              "api/link-action",
              "api/links-action",
              "api/dynamic"
            ]
          },
          {
            "group": "Hooks",
            "pages": [
              "api/use-location",
              "api/use-router",
              "api/use-history"
            ]
          }
        ]
      }
    ]
  }
}
